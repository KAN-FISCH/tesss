local function parseAPIData(apiResponse)
    local parsed = {}
    
    print("[ShielD UI] Starting parse of API rows...")
    
    local success, err = pcall(function()
        if not apiResponse or type(apiResponse) ~= "table" then
            warn("[ShielD UI] Invalid API response format")
            return
        end
        
        if not apiResponse.rows or type(apiResponse.rows) ~= "table" then
            warn("[ShielD UI] API response missing rows")
            return
        end
        
        for idx, row in ipairs(apiResponse.rows) do
            if not row or not row.payload or not row.payload.embeds then continue end
            
            local embed = row.payload.embeds[1]
            if not embed then continue end
            
            local fields = embed.fields or {}
            local serverData = {
                eventStr = "No Events",
                eventList = {},
                uptime = "0M",
                uptimeRaw = 0,
                players = "0/20",
                relic = "0",
                craters = "0",
                weather = "None",
                jobId = nil,
                placeId = game.PlaceId
            }
            
            -- Job ID parsing from description
            if embed.description then
                local desc = tostring(embed.description)
                local jobMatch = desc:match("`([a-f0-9%-]+)`")
                if jobMatch and #jobMatch >= 36 then
                    serverData.jobId = jobMatch
                end
            end
            
            -- Parse fields
            for _, field in ipairs(fields) do
                if field and field.name and field.value then
                    local name = tostring(field.name)
                    local value = tostring(field.value)
                    
                    if name:find("Active Events") then
                        local zones = value:match("```(.-)```") or value
                        zones = zones:gsub("^[,%s]+", ""):gsub("%s+$", "")
                        
                        if zones:find("No active") or zones:find("❌") or zones == "" then
                            serverData.eventStr = "No Events"
                            serverData.eventList = {}
                        else
                            serverData.eventStr = zones
                            serverData.eventList = splitString(zones, ",")
                        end
                        
                    elseif name:find("Uptime") then
                        local uptimeMatch = value:match("```(.-)```")
                        if uptimeMatch then
                            local rawUptime = uptimeMatch:gsub("^%s+", ""):gsub("%s+$", "")
                            serverData.uptime = rawUptime
                            serverData.uptimeRaw = parseUptimeToMinutes(rawUptime)
                        end
                        
                    elseif name:find("Players") then
                        local playersMatch = value:match("```(.-)```")
                        if playersMatch then
                            serverData.players = playersMatch:gsub("^%s+", ""):gsub("%s+$", "")
                        end
                        
                    elseif name:find("Weather") then
                        local weatherMatch = value:match("```(.-)```")
                        if weatherMatch then
                            serverData.weather = weatherMatch:gsub("^%s+", ""):gsub("%s+$", "")
                        end
                        
                    elseif name:find("Star Craters") then
                        local craterNum = value:match("%d+")
                        serverData.craters = craterNum or "0"

                    elseif name:find("Cosmic Relics") then
                        local relicNum = value:match("%d+")
                        serverData.relic = relicNum or "0"
                        
                    elseif name:find("Server Info") or name:find("Place ID") then
                        local placeMatch = value:match("(%d+)")
                        if placeMatch then
                            serverData.placeId = tonumber(placeMatch) or game.PlaceId
                        end
                    end
                end
            end
            
            if serverData.jobId then
                parsed[#parsed + 1] = serverData
            end
        end
    end)
    
    if not success then
        warn("[ShielD UI] Parse fatal error: " .. tostring(err))
    end
    
    -- Default sorting (re-sorted inside populate based on sort mode)
    table.sort(parsed, function(a, b)
        local aPlayers = tonumber(a.players:match("^(%d+)")) or 0
        local bPlayers = tonumber(b.players:match("^(%d+)")) or 0
        return aPlayers > bPlayers
    end)
    
    return parsed
end

-- Teleport join function
function joinServer(placeId, jobId)
    if not placeId or not jobId then
        game.StarterGui:SetCore("SendNotification", {
            Title = "ShielD Servers",
            Text = "❌ Invalid server data",
            Duration = 3
        })
        return
    end
    
    game.StarterGui:SetCore("SendNotification", {
        Title = "ShielD Servers",
        Text = "Connecting to server instance...",
        Duration = 3
    })
    
    local success, err = pcall(function()
        TeleportService:TeleportToPlaceInstance(tonumber(placeId), tostring(jobId), player)
    end)
    
    if not success then
        warn("[ShielD UI] Teleport failed: " .. tostring(err))
        game.StarterGui:SetCore("SendNotification", {
            Title = "ShielD Servers",
            Text = "❌ Teleport failed: " .. tostring(err),
            Duration = 4
        })
    end
end

