-- ---- Drag Resize Interaction & Persistence ----
local resizing = false
local resizeStart = nil
local resizeStartScale = nil
local _activeResizeInput = nil

local SAVE_FILE = "ShieldGUI_size.json"

local function saveScale(scale)
    pcall(function()
        local json = HttpService:JSONEncode({scale = scale})
        writefile(SAVE_FILE, json)
    end)
end

local function loadSavedScale()
    local ok, result = pcall(function()
        if isfile(SAVE_FILE) then
            local raw = readfile(SAVE_FILE)
            return HttpService:JSONDecode(raw)
        end
    end)
    if ok and result and result.scale then
        return result.scale
    end
    return nil
end

local function applyScale(scale)
    local clampedScale = math.clamp(scale, 0.4, 1.5)
    globalUIScale.Scale = clampedScale
end

local function onResizeEnd()
    if resizing then
        resizing = false
        _activeResizeInput = nil
        -- Restore visual indicators if highlighted
        for _, child in ipairs(resizeIconHolder:GetChildren()) do
            if child:IsA("Frame") then
                TweenService:Create(child, TweenInfo.new(0.15), { BackgroundTransparency = 0.4, BackgroundColor3 = THEME.TextMuted }):Play()
            end
        end
        saveScale(globalUIScale.Scale)
    end
end

resizeBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = true
        _activeResizeInput = input
        resizeStart = input.Position
        resizeStartScale = globalUIScale.Scale

        -- Highlight visual handle when drag starts
        for _, child in ipairs(resizeIconHolder:GetChildren()) do
            if child:IsA("Frame") then
                TweenService:Create(child, TweenInfo.new(0.1), { BackgroundTransparency = 0.05, BackgroundColor3 = Color3.fromRGB(59, 130, 246) }):Play()
            end
        end

        input.Changed:Connect(function()
            if resizing and _activeResizeInput == input then
                if input.UserInputState == Enum.UserInputState.Change then
                    local delta = input.Position - resizeStart
                    applyScale(resizeStartScale + (delta.X * 2 / frameWidth))
                elseif input.UserInputState == Enum.UserInputState.End then
                    onResizeEnd()
                end
            end
        end)
    end
end)

if not isMobile then
