(function() {
    'use strict';

    // 1. Skrip untuk memanipulasi tombol/fungsi error di halaman awal
    if (typeof unsafeWindow !== 'undefined') {
        unsafeWindow.goError = function() {
            alert("Fungsi goError telah diblokir dan dialihkan!");

            let existingForm = document.getElementById('form_repputs');
            if (existingForm) {
                let inputJenis = document.getElementById('jenisujian');
                if (inputJenis) {
                    inputJenis.value = 'A';
                } else {
                    alert("Field jenisujian tidak ditemukan di form!");
                }

                existingForm.action = '/siakad/rep_kartuujian';
                existingForm.submit();
            } else {
                alert("Form cetak (form_repputs) tidak ditemukan di halaman ini.");
            }
        };
    }

    // 2. Skrip untuk menyuntikkan HTML jadwal baru di halaman hasil cetak
    // Berjalan otomatis saat halaman selesai dimuat
    window.addEventListener('load', function() {
        // Memastikan ini berjalan hanya di halaman hasil cetak kartu
        if (window.location.href.includes('/siakad/rep_kartuujian')) {
            
            // Buat elemen baris (TR) untuk jadwal baru
            let rowJadwal = document.createElement('tr');
            
            // Sesuaikan struktur <td> di bawah ini dengan urutan kolom tabel di web SIAKAD kampusmu.
            // Contoh urutan umum: Matkul | SKS | Tanggal | Waktu | Ruang | Kursi
            rowJadwal.innerHTML = `
                <td style="padding: 5px; border: 1px solid #000;">Sistem Ekonomi Pancasila</td>
                <td style="padding: 5px; border: 1px solid #000; text-align: center;">2</td>
                <td style="padding: 5px; border: 1px solid #000; text-align: center;">Kamis, 02/07/2026</td>
                <td style="padding: 5px; border: 1px solid #000; text-align: center;">07.45 - 09.25</td>
                <td style="padding: 5px; border: 1px solid #000; text-align: center;">306</td>
                <td style="padding: 5px; border: 1px solid #000; text-align: center;">20</td>
            `;

            // Cari elemen tabel tempat jadwal berada. 
            // Ubah 'table tbody' menjadi selector yang lebih spesifik jika perlu (misal: '#tabel_jadwal tbody')
            let tabelJadwal = document.querySelector('table tbody'); 
            
            if (tabelJadwal) {
                tabelJadwal.appendChild(rowJadwal);
                console.log("Jadwal Sistem Ekonomi Pancasila berhasil ditambahkan.");
            } else {
                console.log("Tabel jadwal tidak ditemukan untuk disuntikkan HTML.");
            }
        }
    });
})();
