local function getEventInfo(eventName)
    local info = EVENT_MAP[eventName]
    if not info then
        local hash = 0
        for i = 1, #eventName do
            hash = hash + string.byte(eventName, i)
        end
        local r = (hash * 37) % 150 + 80
        local g = (hash * 67) % 150 + 80
        local b = (hash * 107) % 150 + 80
        info = { color = Color3.fromRGB(r, g, b), name = eventName }
    end
    return info
end

