local function buildDropdownOption(name, filterVal)
    local opt = Instance.new("TextButton")
    opt.Size = UDim2.new(1, 0, 0, 20)
    opt.BackgroundColor3 = Color3.fromRGB(25, 28, 38)
    opt.BorderSizePixel = 0
    opt.Font = Enum.Font.GothamBold
    opt.Text = name
    opt.TextColor3 = THEME.TextMuted
    opt.TextSize = 8
    opt.AutoButtonColor = false
    opt.Parent = filterDropdown

    local optCorner = Instance.new("UICorner")
    optCorner.CornerRadius = UDim.new(0, 5)
    optCorner.Parent = opt

    opt.MouseEnter:Connect(function()
        opt.TextColor3 = THEME.Text
        opt.BackgroundColor3 = THEME.CardHoverBg
    end)

    opt.MouseLeave:Connect(function()
        if currentFilter ~= filterVal then
            opt.TextColor3 = THEME.TextMuted
            opt.BackgroundColor3 = Color3.fromRGB(25, 28, 38)
        end
    end)

    opt.MouseButton1Click:Connect(function()
        currentFilter = filterVal
        filterButton.Text = "Filters: " .. name
        filterDropdown.Visible = false
        currentPage = 1
        
        -- Reset highlights
        for _, child in ipairs(filterDropdown:GetChildren()) do
            if child:IsA("TextButton") then
                child.BackgroundColor3 = Color3.fromRGB(25, 28, 38)
                child.TextColor3 = THEME.TextMuted
            end
        end
        opt.BackgroundColor3 = THEME.Accent
        opt.TextColor3 = THEME.Text
        
        populate(searchBar.Text)
    end)
    
    if currentFilter == filterVal then
        opt.BackgroundColor3 = THEME.Accent
        opt.TextColor3 = THEME.Text
    end
end

