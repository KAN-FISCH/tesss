-- Refresh and fetch API data
local function fetchServers()
    isRefreshing = true
    lastUpdateLabel.Text = "Updating servers..."
    
    -- Sync animation rotation
    local rotateTween = TweenService:Create(syncIcon, TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1), { Rotation = 360 })
    rotateTween:Play()

    local rawData = httpGet(API_URL)
    rotateTween:Cancel()
    syncIcon.Rotation = 0

    if not rawData then
        warn("[ShielD UI] Failed to get response from API")
        lastUpdateLabel.Text = "Connection Error!"
        isRefreshing = false
        return false
    end

    local decodeSuccess, decoded = pcall(function()
        return HttpService:JSONDecode(rawData)
    end)

    if not decodeSuccess or not decoded then
        warn("[ShielD UI] JSON decoding error")
        lastUpdateLabel.Text = "Data Error!"
        isRefreshing = false
        return false
    end

    allServers = parseAPIData(decoded)
    
    -- Update stats counters labels
    if onlineCountLabel then onlineCountLabel.Text = tostring(#allServers) end
    
    local totalPlayers = 0
    for _, s in ipairs(allServers) do
        local pCount = tonumber(s.players:match("^(%d+)")) or 0
        totalPlayers = totalPlayers + pCount
    end
    local avgVal = #allServers > 0 and math.round(totalPlayers / #allServers) or 0
    if avgPlayersLabel then avgPlayersLabel.Text = avgVal .. " / 20" end
    
    local totalCraters = 0
    local totalRelics = 0
    for _, s in ipairs(allServers) do
        totalCraters = totalCraters + (tonumber(s.craters) or 0)
        totalRelics = totalRelics + (tonumber(s.relic) or 0)
    end
    if totalCratersLabel then totalCratersLabel.Text = tostring(totalCraters) end
    if totalRelicsLabel then totalRelicsLabel.Text = tostring(totalRelics) end
    
    -- Update dynamic events row
    updateGlobalEventsRow()
    
    -- Dynamic timestamp footer
    local t = os.date("*t")
    local ts = string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
    lastUpdateLabel.Text = "Last Update: Today, " .. ts
    
    isRefreshing = false
    return true
end

-- Populates the scroll panel based on search, filters, and sort options
function populate(searchQuery)
    -- Clear current display rows (prevent duplicates and leaking text labels)
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
            child:Destroy()
        end
    end
    
    filteredServers = {}
    searchQuery = searchQuery and string.lower(searchQuery) or ""

    for _, s in ipairs(allServers) do
        local matchesSearch = true
        if searchQuery ~= "" then
            local serverId = string.lower(s.jobId or "")
            local events = string.lower(s.eventStr or "")
            matchesSearch = string.find(serverId, searchQuery) or string.find(events, searchQuery)
        end

        local matchesFilter = true
        if currentFilter == "Pliosaur Hunt" then
            matchesFilter = false
            for _, ev in ipairs(s.eventList) do
                if ev:find("Pliosaur") then matchesFilter = true break end
            end
        elseif currentFilter == "Kraken Pool" then
            matchesFilter = false
            for _, ev in ipairs(s.eventList) do
                if ev:find("Kraken") then matchesFilter = true break end
            end
        elseif currentFilter == "Sunken Reliquary" then
            matchesFilter = false
            for _, ev in ipairs(s.eventList) do
                if ev:find("Sunken Reliquary") then matchesFilter = true break end
            end
        elseif currentFilter == "Craters" then
            matchesFilter = tonumber(s.craters) > 0
        elseif currentFilter == "Relics" then
            matchesFilter = tonumber(s.relic) > 0
        end

        if matchesSearch and matchesFilter then
            filteredServers[#filteredServers + 1] = s
        end
    end

    -- Handle advanced sorting modes
    if currentSort == "Players" then
        table.sort(filteredServers, function(a, b)
            local aPlayers = tonumber(a.players:match("^(%d+)")) or 0
            local bPlayers = tonumber(b.players:match("^(%d+)")) or 0
            if aPlayers ~= bPlayers then
                return aPlayers > bPlayers
            end
            return (a.jobId or "") > (b.jobId or "")
        end)
    elseif currentSort == "Events" then
        table.sort(filteredServers, function(a, b)
            local aEvents = #a.eventList
            local bEvents = #b.eventList
            if aEvents ~= bEvents then
                return aEvents > bEvents
            end
            return (a.jobId or "") > (b.jobId or "")
        end)
    elseif currentSort == "Craters" then
        table.sort(filteredServers, function(a, b)
            local aCraters = tonumber(a.craters) or 0
            local bCraters = tonumber(b.craters) or 0
            if aCraters ~= bCraters then
                return aCraters > bCraters
            end
            return (a.jobId or "") > (b.jobId or "")
        end)
    elseif currentSort == "Relics" then
        table.sort(filteredServers, function(a, b)
            local aRelics = tonumber(a.relic) or 0
            local bRelics = tonumber(b.relic) or 0
            if aRelics ~= bRelics then
                return aRelics > bRelics
            end
            return (a.jobId or "") > (b.jobId or "")
        end)
    end

    -- Update pagination bounds
    local totalPages = math.max(1, math.ceil(#filteredServers / pageSize))
    currentPage = math.clamp(currentPage, 1, totalPages)

    -- Clear pagination panel controls
    for _, child in ipairs(paginationFrame:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("TextLabel") then
            child:Destroy()
        end
    end

    -- Draw server rows for the current page
    local startIndex = (currentPage - 1) * pageSize + 1
    local endIndex = math.min(currentPage * pageSize, #filteredServers)

    if #filteredServers == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Name = "EmptyLabel"
        emptyLabel.Size = UDim2.new(1, 0, 0, 50)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Font = Enum.Font.GothamMedium
        emptyLabel.Text = "No matching active servers found."
        emptyLabel.TextColor3 = THEME.TextMuted
        emptyLabel.TextSize = 12
        emptyLabel.Parent = scrollFrame
    else
        for idx = startIndex, endIndex do
            local rowItem = createServerRow(filteredServers[idx], idx)
            rowItem.Parent = scrollFrame
        end
    end

    -- Build pagination control bar
    if totalPages > 1 then
        local lo = 0
        local function addBtn(text, targetPage, active, enabled)
            lo = lo + 1
            createPaginationButton(text, targetPage, active, enabled, lo)
        end
        
        -- Previous page arrow
        addBtn("<", currentPage - 1, false, currentPage > 1)
        
        -- Individual page buttons (smart page numbering slider)
        local startP = math.max(1, currentPage - 2)
        local endP = math.min(totalPages, startP + 4)
        if endP - startP < 4 then
            startP = math.max(1, endP - 4)
        end

        if startP > 1 then
            addBtn("1", 1, false, true)
            if startP > 2 then
                lo = lo + 1
                local dotLabel = Instance.new("TextLabel")
                dotLabel.LayoutOrder = lo
                dotLabel.Size = UDim2.new(0, 20, 0, 22)
                dotLabel.BackgroundTransparency = 1
                dotLabel.Font = Enum.Font.GothamBold
                dotLabel.Text = "..."
                dotLabel.TextColor3 = THEME.TextMuted
                dotLabel.TextSize = 9
                dotLabel.Parent = paginationFrame
            end
        end

        for p = startP, endP do
            addBtn(tostring(p), p, p == currentPage, true)
        end

        if endP < totalPages then
            if endP < totalPages - 1 then
                lo = lo + 1
                local dotLabel = Instance.new("TextLabel")
                dotLabel.LayoutOrder = lo
                dotLabel.Size = UDim2.new(0, 20, 0, 22)
                dotLabel.BackgroundTransparency = 1
                dotLabel.Font = Enum.Font.GothamBold
                dotLabel.Text = "..."
                dotLabel.TextColor3 = THEME.TextMuted
                dotLabel.TextSize = 9
                dotLabel.Parent = paginationFrame
            end
            addBtn(tostring(totalPages), totalPages, false, true)
        end

        -- Next page arrow
        addBtn(">", currentPage + 1, false, currentPage < totalPages)
    end
end

