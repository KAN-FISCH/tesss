local function createPaginationButton(text, targetPage, active, enabled, layoutOrder)
    local btn = Instance.new("TextButton")
    btn.LayoutOrder = layoutOrder or 0
    btn.Size = UDim2.new(0, 22, 0, 22)
    btn.BackgroundColor3 = active and THEME.Accent or Color3.fromRGB(24, 28, 40)
    btn.Font = Enum.Font.GothamBold
    btn.Text = text
    btn.TextColor3 = active and THEME.Text or (enabled and THEME.TextMuted or Color3.fromRGB(70, 75, 90))
    btn.TextSize = 9
    btn.AutoButtonColor = false
    btn.Parent = paginationFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 5)
    btnCorner.Parent = btn

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 0.8
    btnStroke.Color = active and THEME.AccentStroke or THEME.Border
    btnStroke.Parent = btn

    if enabled and not active then
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), { BackgroundColor3 = THEME.CardHoverBg }):Play()
            btn.TextColor3 = THEME.Text
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), { BackgroundColor3 = Color3.fromRGB(24, 28, 40) }):Play()
            btn.TextColor3 = THEME.TextMuted
        end)
        btn.MouseButton1Click:Connect(function()
            currentPage = targetPage
            populate(searchBar.Text)
        end)
    end
end

