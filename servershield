    local bcCorner = Instance.new("UICorner")
    bcCorner.CornerRadius = UDim.new(0.5, 0)
    bcCorner.Parent = barContainer

    local barFill = Instance.new("Frame")
    barFill.Size = UDim2.new(fillRatio, 0, 1, 0)
    barFill.BackgroundColor3 = THEME.Green
    barFill.BorderSizePixel = 0
    barFill.Parent = barContainer

    local bfCorner = Instance.new("UICorner")
    bfCorner.CornerRadius = UDim.new(0.5, 0)
    bfCorner.Parent = barFill

    -- Events Column (X = 290, width = 250)
    local eventsCountText = Instance.new("TextLabel")
    eventsCountText.Size = UDim2.new(0, 100, 0, 12)
    eventsCountText.Position = UDim2.new(0, 290, 0, 4)
    eventsCountText.BackgroundTransparency = 1
    eventsCountText.Font = Enum.Font.GothamBold
    eventsCountText.Text = #data.eventList .. " Events"
    eventsCountText.TextColor3 = THEME.Green
    eventsCountText.TextSize = 8
    eventsCountText.TextXAlignment = Enum.TextXAlignment.Left
    eventsCountText.Parent = row

    local eventsContainer = Instance.new("Frame")
    eventsContainer.Size = UDim2.new(0, 250, 0, 12)
    eventsContainer.Position = UDim2.new(0, 290, 0, 18)
    eventsContainer.BackgroundTransparency = 1
    eventsContainer.AutomaticSize = Enum.AutomaticSize.Y
    eventsContainer.Parent = row

    local evLayout = Instance.new("UIListLayout")
    evLayout.FillDirection = Enum.FillDirection.Horizontal
    evLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    evLayout.Wraps = true
    evLayout.Padding = UDim.new(0, 4)
    evLayout.Parent = eventsContainer

    -- Draw event badge items
    local drawCount = #data.eventList
    local maxBadges = 9
    if drawCount > maxBadges then maxBadges = 8 end

    for i = 1, math.min(drawCount, maxBadges) do
        local evName = data.eventList[i]
        local evInfo = getEventInfo(evName)
        
        local badge = Instance.new("Frame")
        badge.AutomaticSize = Enum.AutomaticSize.X
        badge.Size = UDim2.new(0, 0, 0, 12)
        badge.BackgroundColor3 = Color3.fromRGB(15, 12, 25)
        badge.Parent = eventsContainer
        
        local badgeCorner = Instance.new("UICorner")
        badgeCorner.CornerRadius = UDim.new(0, 3)
