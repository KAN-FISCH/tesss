    descLabel.TextColor3 = THEME.TextMuted
    descLabel.TextSize = 7
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.TextTruncate = Enum.TextTruncate.AtEnd
    descLabel.Parent = row

    -- Players Column (Ratio + Green Progress Bar)
    local curPlayers, maxPlayers = data.players:match("^(%d+)%s*/%s*(%d+)")
    curPlayers = tonumber(curPlayers) or 0
    maxPlayers = tonumber(maxPlayers) or 20
    local fillRatio = math.clamp(curPlayers / maxPlayers, 0, 1)

    local playersLabel = Instance.new("TextLabel")
    playersLabel.Size = UDim2.new(0, 60, 0, 12)
    playersLabel.Position = UDim2.new(0, 220, 0, 4)
    playersLabel.BackgroundTransparency = 1
