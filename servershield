-- Helper to split a string by delimiter
local function splitString(str, sep)
    local result = {}
    for match in string.gmatch(str, "([^" .. sep .. "]+)") do
        local cleaned = match:gsub("^%s+", ""):gsub("%s+$", "")
        result[#result + 1] = cleaned
    end
    return result
end

-- Helper to parse uptime string into raw minutes for sorting
local function parseUptimeToMinutes(uptimeStr)
    local d = tonumber(uptimeStr:match("(%d+)D") or uptimeStr:match("(%d+)d") or 0)
    local h = tonumber(uptimeStr:match("(%d+)H") or uptimeStr:match("(%d+)h") or 0)
    local m = tonumber(uptimeStr:match("(%d+)M") or uptimeStr:match("(%d+)m") or 0)
    return d * 1440 + h * 60 + m
end

-- Helper to clean uptime string formatting
local function cleanUptime(str)
    str = str:gsub("```", ""):gsub("%s+$", ""):gsub("^%s+", "")
    str = str:gsub("^0D%s*", ""):gsub("^0d%s*", "")
    str = str:gsub("H", "h"):gsub("M", "m"):gsub("D", "d")
    return str
end

-- Fallback HTTP request logic
local function httpGet(url)
    if http_request then
        local success, res = pcall(function()
            return http_request({
                Url = url,
                Method = "GET",
                Headers = {
                    ["Content-Type"] = "application/json",
                    ["User-Agent"] = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
                }
            })
        end)
        if success and res and res.Body then
            return res.Body
        end
    end
    local success, body = pcall(function()
        return game:HttpGet(url)
    end)
    if success and body then
        return body
    end
    local success2, body2 = pcall(function()
        return game:GetService("HttpService"):GetAsync(url)
    end)
    if success2 and body2 then
        return body2
    end
    return nil
end

-- Generate a hash-based ping for visual UI consistency
local function getPing(jobId)
    if not jobId then return "45ms" end
    local hash = 0
    for i = 1, #jobId do
        hash = hash + string.byte(jobId, i)
    end
    local p = 20 + (hash % 60)
    return p .. "ms"
end

