-- Helper to draw a single line segment
local function drawLine(parent, x1, y1, x2, y2, color, thickness, transparency)
    local dx = x2 - x1
    local dy = y2 - y1
    local length = math.sqrt(dx*dx + dy*dy)
    local angle = math.deg(math.atan2(dy, dx))
    
    local line = Instance.new("Frame")
    line.Size = UDim2.new(0, length, 0, thickness)
    line.Position = UDim2.new(0, (x1 + x2)/2, 0, (y1 + y2)/2)
    line.AnchorPoint = Vector2.new(0.5, 0.5)
    line.Rotation = angle
    line.BackgroundColor3 = color
    line.BackgroundTransparency = transparency or 0
    line.BorderSizePixel = 0
    line.Parent = parent
    return line
end

-- Helper to draw a horizontal hexagon outline (<_>)
local function createHexagonOutline(parent, W, H, d, color, thickness, transparency)
    local lines = {}
    
    local p1 = { x = 0, y = H/2 }
    local p2 = { x = d, y = 0 }
    local p3 = { x = W - d, y = 0 }
    local p4 = { x = W, y = H/2 }
    local p5 = { x = W - d, y = H }
    local p6 = { x = d, y = H }
    
    local segments = {
        {p1, p2},
        {p2, p3},
        {p3, p4},
        {p4, p5},
        {p5, p6},
        {p6, p1}
    }
    
    for _, seg in ipairs(segments) do
        local line = drawLine(parent, seg[1].x, seg[1].y, seg[2].x, seg[2].y, color, thickness, transparency)
        lines[#lines + 1] = line
    end
    
    return lines
end

